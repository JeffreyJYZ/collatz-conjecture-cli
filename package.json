{
  "name": "collatz-conjecture-cli",
  "version": "1.0.1",
  "description": "Outputs the Collatz Conjecture sequence of a given positive integer.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "JeffreyJYZ",
  "main": "dist/cli.js",
  "module": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "exports": {
    ".": {
      "import": "./dist/cli.js"
    }
  },
  "bin": {
    "collatz-conj": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "collatz",
    "conjecture",
    "cli",
    "math",
    "3n+1",
    "sequence"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=node --format=esm --outfile dist/cli.js --minify",
    "compile:native": "bun build --compile src/index.ts --outfile index",
    "format": "prettier --write .",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeffreyJYZ/collatz-conjecture-cli.git"
  },
  "bugs": {
    "url": "https://github.com/JeffreyJYZ/collatz-conjecture-cli/issues"
  },
  "homepage": "https://github.com/JeffreyJYZ/collatz-conjecture-cli#readme"
}
